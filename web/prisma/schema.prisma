generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model games {
  id              Int               @id @default(autoincrement())
  name            String            @unique @db.VarChar(100)
  min_players     Int               @default(1)
  max_players     Int
  matches         matches[]
  user_game_stats user_game_stats[]
}

model users {
  id                       String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  provider                 String    @db.VarChar(50)
  provider_id              String    @db.VarChar(255)
  nickname                 String    @db.VarChar(100)
  avatar_emoji             String    @db.VarChar(1)
  avatar_image_key         String?
  avatar_image_updated_at  DateTime? @db.Timestamptz(6)
  created_at               DateTime? @default(now()) @db.Timestamptz(6)

  match_players                match_players[]
  matches                      matches[]
  user_game_stats              user_game_stats[]
  home_notices                 home_notices[]
  admin_users                  admin_users?
  mahjong_user_achievements    mahjong_user_achievements[]
  mahjong_user_badges          mahjong_user_badges[]
  mahjong_user_equipped_badges mahjong_user_equipped_badges[]
  mahjong_news_events mahjong_news_events[]

  @@unique([provider, provider_id])
}

model admin_users {
  id         Int      @id @default(autoincrement())
  user_id    String   @unique @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model user_game_stats {
  id                Int    @id @default(autoincrement())
  user_id           String @db.Uuid
  game_id           Int
  play_count        Int    @default(0)
  accumulated_score Int    @default(0)
  average_rank      Float?
  mmr               Int    @default(1500)
  specific_stats    Json?
  games             games  @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users             users  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, game_id])
}

model matches {
  id         Int       @id @default(autoincrement())
  game_id    Int
  created_by String?   @db.Uuid
  play_date  DateTime? @default(now()) @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  deleted_by String?   @db.Uuid

  match_details match_details?
  match_players match_players[]
  mahjong_news_events mahjong_news_events[]

  users users? @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  games games @relation(fields: [game_id], references: [id], onUpdate: NoAction)

  @@index([game_id, deleted_at, play_date])
}

model match_details {
  match_id Int @id

  details Json

  // 동시 기록 방지용 낙관적 잠금 버전
  version Int @default(0)

  matches matches @relation(fields: [match_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model match_players {
  id          Int     @id @default(autoincrement())
  match_id    Int
  user_id     String? @db.Uuid
  guest_name  String? @db.VarChar(100)
  final_score Int?
  rank        Int?
  matches     matches @relation(fields: [match_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users?  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model home_notices {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(200)
  summary      String?  @db.VarChar(500)
  content      String?
  category     String   @default("NOTICE") @db.VarChar(30)
  is_pinned    Boolean  @default(false)
  is_published Boolean  @default(true)
  created_by   String?  @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  users        users?   @relation(fields: [created_by], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([is_published, is_pinned, created_at])
  @@index([category])
}

model mahjong_user_achievements {
  id             Int    @id @default(autoincrement())
  user_id        String @db.Uuid
  achievement_id String @db.VarChar(100)

  progress     Int       @default(0)
  completed    Boolean   @default(false)
  completed_at DateTime? @db.Timestamptz(6)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, achievement_id])
  @@index([user_id])
  @@index([achievement_id])
}

model mahjong_user_badges {
  id       Int    @id @default(autoincrement())
  user_id  String @db.Uuid
  badge_id String @db.VarChar(100)

  earned_at DateTime @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, badge_id])
  @@index([user_id])
  @@index([badge_id])
}

model mahjong_user_equipped_badges {
  id       Int    @id @default(autoincrement())
  user_id  String @db.Uuid
  badge_id String @db.VarChar(100)
  slot     Int

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, slot])
  @@unique([user_id, badge_id])
  @@index([user_id])
  @@index([badge_id])
}

model mahjong_news_events {
  id             Int      @id @default(autoincrement())
  event_key      String   @unique @db.VarChar(200)
  event_type     String   @db.VarChar(30)

  user_id        String   @db.Uuid
  match_id       Int?

  achievement_id String?  @db.VarChar(100)
  yaku_id        String?  @db.VarChar(100)

  title          String   @db.VarChar(200)
  message        String   @db.VarChar(500)
  metadata       Json?

  occurred_at    DateTime @default(now()) @db.Timestamptz(6)
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  users          users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  matches        matches? @relation(fields: [match_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([event_type, occurred_at])
  @@index([user_id, occurred_at])
  @@index([match_id])
  @@index([achievement_id])
}